# =============================================
# TimeBlock 后端 API 服务 - 环境变量配置
# =============================================
# 双数据库架构: SQLite (本地开发) / MySQL (生产)
# =============================================

# 服务端口
PORT=3000

# 环境 (development / production / test)
NODE_ENV=development

# =============================================
# 数据库配置
# =============================================
# DB_DIALECT: mysql (生产默认) / sqlite (开发)
DB_DIALECT=mysql

# === MySQL 配置 ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=time_block
DB_USER=root
DB_PASSWORD=root

# === SQLite 配置 (仅 DB_DIALECT=sqlite 时生效) ===
# DB_STORAGE=./data/timeblock.db

# =============================================
# JWT 认证配置
# =============================================
JWT_SECRET=timeblock-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# =============================================
# 安全配置
# =============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

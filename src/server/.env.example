# 服务端口
PORT=3000

# 数据库配置 (MySQL / SQLite)
DB_DIALECT=sqlite
DB_STORAGE=./data/timeblock.db

# MySQL 配置 (当 DB_DIALECT=mysql 时生效)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=time_block
# DB_USER=root
# DB_PASSWORD=root

# JWT 密钥
JWT_SECRET=timeblock-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 加密密钥 (用于 WebDAV 密码等敏感数据)
ENCRYPTION_KEY=timeblock-aes-256-encryption-key-32ch

# 环境
NODE_ENV=development
